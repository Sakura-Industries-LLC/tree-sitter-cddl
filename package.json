{
  "name": "tree-sitter-cddl",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for CDDL, the Concise Data Definition Language for CBOR and JSON data structures.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakura-industries-llc/tree-sitter-cddl.git"
  },
  "funding": "",
  "license": "MIT OR Apache-2.0",
  "author": {
    "name": "Steven Johnson",
    "email": "steven.johnson@sakuraindustries.net",
    "url": "https://sakuraindustries.net"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "cddl"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.9"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
